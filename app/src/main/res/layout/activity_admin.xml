<?xml version="1.0" encoding="utf-8"?>

<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ══════════════════════════════════════════
         KONTEN UTAMA
    ══════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#F0F4FA">

        <!-- Toolbar -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#0D3B78"
            app:title="Admin Dashboard"
            app:titleTextColor="#FFFFFF"/>

        <!-- Scrollable dashboard content -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Greeting -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Selamat Datang, Admin 👋"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvTanggalHariIni"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Senin, 09 Juni 2025"
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:layout_marginBottom="20dp"/>

                <!-- ── Kartu Statistik Hari Ini ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📊  Ringkasan Hari Ini"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E"
                    android:layout_marginBottom="10dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="20dp">

                    <!-- Kartu: Total Penjualan Hari Ini -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_card_blue"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💰 Penjualan Hari Ini"
                            android:textColor="#BBDEFB"
                            android:textSize="12sp"/>

                        <TextView
                            android:id="@+id/tvPenjualanHariIni"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rp 0"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:layout_marginTop="6dp"/>

                    </LinearLayout>

                    <!-- Kartu: Jumlah Transaksi Hari Ini -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_card_green"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🧾 Transaksi Hari Ini"
                            android:textColor="#C8E6C9"
                            android:textSize="12sp"/>

                        <TextView
                            android:id="@+id/tvTransaksiHariIni"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#FFFFFF"
                            android:textSize="32sp"
                            android:textStyle="bold"
                            android:layout_marginTop="6dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="transaksi"
                            android:textColor="#C8E6C9"
                            android:textSize="11sp"/>

                    </LinearLayout>

                </LinearLayout>

                <!-- ── Line Chart ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_white"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📈  Penjualan 7 Hari Terakhir"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A2E"
                        android:layout_marginBottom="12dp"/>

                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/lineChart"
                        android:layout_width="match_parent"
                        android:layout_height="220dp"/>

                    <!-- Legend -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginTop="8dp">

                        <View
                            android:layout_width="16dp"
                            android:layout_height="3dp"
                            android:background="#1565C0"
                            android:layout_marginEnd="6dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total Penjualan (Rp)"
                            android:textSize="11sp"
                            android:textColor="#666666"/>

                    </LinearLayout>

                </LinearLayout>

                <!-- ── Transaksi Terbaru Hari Ini ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🕐  Transaksi Terbaru Hari Ini"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="10dp"/>

                <LinearLayout
                    android:id="@+id/containerTransaksiHariIni"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>

                <TextView
                    android:id="@+id/tvNoTransaksiHariIni"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Belum ada transaksi hari ini"
                    android:textColor="#AAAAAA"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:padding="16dp"
                    android:visibility="gone"/>

            </LinearLayout>
        </ScrollView>

    </LinearLayout>

    <!-- ══════════════════════════════════════════
         SIDEBAR
    ══════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/sidebar"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#0D3478"
        android:orientation="vertical">

        <!-- Search Box -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:background="#3FF1F4"
            android:gravity="center">

            <EditText
                android:id="@+id/etSearch"
                android:layout_width="250dp"
                android:layout_height="45dp"
                android:background="#FFFFFF"
                android:hint="Pencarian Menu"
                android:padding="10dp" />
        </LinearLayout>

        <!-- Logo / Judul -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:text="CERUS ADMIN"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"/>

        <!-- Menu -->
        <TextView
            android:id="@+id/menuDashboard"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:text="Dashboard"
            android:textColor="#FFFFFF"
            android:textSize="18sp"/>

        <TextView
            android:id="@+id/menuProduk"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:text="Kelola Produk"
            android:textColor="#FFFFFF"
            android:textSize="18sp"/>

        <TextView
            android:id="@+id/menuLaporan"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:text="Laporan Penjualan"
            android:textColor="#FFFFFF"
            android:textSize="18sp"/>

        <TextView
            android:id="@+id/menuLogout"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:text="Logout"
            android:textColor="#FFFFFF"
            android:textSize="18sp"/>

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>