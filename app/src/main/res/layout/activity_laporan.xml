<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FA">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#0D3B78"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <Button
            android:id="@+id/btnKembaliLaporan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="‹ Kembali"
            android:textColor="#FFFFFF"
            android:background="@android:color/transparent"
            android:textSize="16sp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Laporan Penjualan"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"/>

        <View
            android:layout_width="80dp"
            android:layout_height="wrap_content"/>

    </LinearLayout>

    <!-- Total Pendapatan -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1A56A8"
        android:padding="16dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Total Pendapatan"
            android:textColor="#BBDEFB"
            android:textSize="13sp"/>

        <TextView
            android:id="@+id/tvTotalPendapatan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rp 0"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvJumlahTransaksi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 transaksi"
            android:textColor="#BBDEFB"
            android:textSize="13sp"
            android:layout_marginTop="4dp"/>

    </LinearLayout>

    <!-- Label -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Riwayat Transaksi"
        android:textStyle="bold"
        android:textSize="15sp"
        android:textColor="#333333"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp"/>

    <!-- List Transaksi -->
    <ListView
        android:id="@+id/listLaporan"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="#E0E0E0"
        android:dividerHeight="1dp"
        android:background="#FFFFFF"/>

    <!-- Empty state -->
    <TextView
        android:id="@+id/tvEmptyLaporan"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="Belum ada transaksi"
        android:textColor="#AAAAAA"
        android:textSize="16sp"
        android:visibility="gone"/>

</LinearLayout>